{
  "expo": {
    "name": "하루",
    "slug": "haru-rn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "haru",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sigcrew.haru",
      "buildNumber": "20",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F6EFE2",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.sigcrew.haru"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "./plugins/withModularHeaders",
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#F6EFE2",
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.211797293864-6594apko9jt9dql1tk874k0li3lc5a93"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7bc65326-47a9-4ad7-ae6e-9845d2fdc603"
      }
    },
    "owner": "terra586"
  }
}
