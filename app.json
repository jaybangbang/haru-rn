{
  "expo": {
    "name": "Perpetual",
    "slug": "haru-rn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "perpetual",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ing.perpetual.app",
      "buildNumber": "36",
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "appleTeamId": "867RGMZD7Y"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F6EFE2",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "ing.perpetual.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "./plugins/withModularHeaders",
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#F6EFE2",
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.785797626728-gl04q5erv10i18pbef9qtsp6coehkk8k"
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7bc65326-47a9-4ad7-ae6e-9845d2fdc603"
      }
    },
    "owner": "terra586"
  }
}
